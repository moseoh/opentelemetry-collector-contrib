              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Device"
          }
        ]
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "hw_temperature_celsius",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "hw_temperature_limit_celsius{limit_type=\"high.critical\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "hw_temperature_limit_celsius{limit_type=\"high.degraded\"}",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "hw_temperature_limit_celsius{limit_type=\"low.critical\"}",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ],
      "title": "Hardware Temperature Overview",
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "Device": {
                "aggregations": [],
                "operation": "groupby"
              },
              "Sensor": {
                "aggregations": [],
                "operation": "groupby"
              },
              "Value": {
                "aggregations": ["lastNotNull"],
                "operation": "aggregate"
              },
              "parent": {
                "aggregations": [],
                "operation": "groupby"
              },
              "sensor_location": {
                "aggregations": [],
                "operation": "groupby"
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "otel_scope_name": true,
              "otel_scope_version": true
            },
            "indexByName": {},
            "renameByName": {
              "Value (lastNotNull)": "Current Temp",
              "Value #B (lastNotNull)": "Critical Limit",
              "Value #C (lastNotNull)": "Warning Limit", 
              "Value #D (lastNotNull)": "Low Critical",
              "parent": "Device",
              "sensor_location": "Sensor"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Display Name",
            "mode": "formula",
            "reduce": {
              "reducer": "sum"
            },
            "replaceFields": false,
            "formula": "if($Device == $Sensor, $Device, concat($Device, ' - ', $Sensor))"
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": "Prometheus",
